# =============================================================
# FICHIER D'EXEMPLE DE CONFIGURATION — NE PAS MODIFIER
# Copiez ce fichier et renommez-le en ".env" puis remplissez
# les valeurs réelles. Ne jamais committer le fichier ".env"!
# =============================================================

# --- BACKEND SETTINGS ---
PORT=5000
MONGO_URI=mongodb://localhost:27017/your_database_name

# Secret JWT — utilisez une chaîne longue et aléatoire en production
# Exemple : openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_here

# --- ADMIN SEEDING ---
# Ces identifiants sont utilisés pour créer le compte administrateur initial
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_strong_password_here
ADMIN_NAME=Admin
ADMIN_FORCE_RESET=true

# --- FRONTEND SETTINGS ---
NEXT_PUBLIC_API_URL=/api
CLIENT_URL=http://localhost:3000
